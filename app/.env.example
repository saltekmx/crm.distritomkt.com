# ── API Configuration ──────────────────────────────────────────────
# Two modes:
#   LOCAL  → API runs on localhost:8000, Vite proxies /api/* to it
#   REMOTE → API is the deployed dev server, Vite proxies /api/* to it
#
# VITE_API_URL        — Used by Axios (goes through Vite proxy)
# VITE_API_PUBLIC_URL — Used for OAuth redirects (browser navigates directly)

# Local API (default for development):
VITE_API_URL=http://localhost:5174
VITE_API_PUBLIC_URL=http://localhost:8000

# Remote API (uncomment these, comment out the above):
# VITE_API_URL=http://localhost:5174
# VITE_API_PUBLIC_URL=https://api-dev-distritomkt-com.saltek.mx
